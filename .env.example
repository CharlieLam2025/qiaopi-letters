# 把这个文件复制为 .env.local，然后把空值填上。
# .env.local 已经在 .gitignore 中，不会被 commit。

# ── DeepSeek（AI 写信） ──────────────────────────────────
# 在 https://platform.deepseek.com 注册后取 key
# /api/compose 路由会读取这个 key 给用户做"那个年代的笔触"润色 / 代写
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Supabase（原件库 + 公开侨批墙） ──────────────────────
# 侨批原件库（/archive）默认使用 src/lib/archiveMock.ts 中的 12 条占位数据。
# 公开侨批墙（/wall）默认存 localStorage（只你自己能看到）。
# 配置以下环境变量后，会改为从 Supabase 拉取 + 写入；失败时回退。

# Supabase 项目地址（https://xxxx.supabase.co）
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon public key（Project settings → API）—— 客户端可见
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role key —— 永远不要暴露给浏览器。仅 API route 用。
SUPABASE_SERVICE_ROLE_KEY=

# 期望的表结构（PostgreSQL）：
# create table qiaopi_items (
#   id text primary key,
#   title text not null,
#   year text not null,
#   date_text text,
#   from_country text, from_city text,
#   to_province text, to_city text, to_village text,
#   sender text, receiver text, receiver_relation text,
#   amount text, currency text,
#   qiaopi_office text,
#   themes text[],
#   images jsonb,        -- ArchiveImage[]
#   transcription text,
#   modern_explanation text,
#   historical_notes text,
#   source_name text, source_url text, rights_note text,
#   created_at timestamptz default now()
# );
#
# 注：当前 lib/archiveStore.ts 直接 select(*)。若你的列名用 snake_case，
# 需要在 store 里加一层映射，或在 Supabase 端建一个返回驼峰字段的 view。
